# Environment Configuration
PORT=3000

# Firebase Configuration
# Loaded automatically from firebase-applet-config.json

# SMTP Configuration for Welcome Emails
# Plug in your custom SMTP details (Gmail App Password, Brevo, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME="INVEST EMPOWERMENT"
SMTP_FROM_EMAIL=no-reply@investempowerment.com
